@page
@model AnimalShelter.Pages.Admin.RequestsModel
@using AnimalShelter.Helpers

@{
    ViewData["Title"] = "Заявки за осиновяване (Admin)";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">
        @TempData["Error"]
    </div>
}

<h1 class="mb-4">Заявки за осиновяване</h1>

<a class="btn btn-primary mb-3" asp-page="/Admin/Animals/Create">+ Добави животно</a>

@if (!Model.Requests.Any())
{
    <p>Няма подадени заявки.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Животно</th>
                <th>Кандидат</th>
                <th>Телефон</th>
                <th>Имейл</th>
                <th>Дата</th>
                <th>Статус</th>
                <th>Коментар</th>
                <th style="width:220px;">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Requests)
            {
                <tr>
                    <td>
                        <strong>@r.Animal?.Name</strong><br />
                        <a asp-page="/Animals/Details" asp-route-id="@r.AnimalId">Детайли</a>
                    </td>
                    <td>@r.FullName</td>
                    <td>@r.Phone</td>
                    <td>@r.Email</td>
                    <td>@r.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@r.Status.GetDisplayName()</td>
                    <td>
                        @if (r.Status == AnimalShelter.Models.Enums.RequestStatus.New)
                        {
                            <form method="post" asp-page-handler="Approve" class="d-inline">
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Одобри</button>
                            </form>

                            <form method="post" asp-page-handler="Reject" class="d-inline ms-2">
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Откажи</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">Няма действия</span>
                        }
                    </td>

                    <td>
                        @if (!string.IsNullOrWhiteSpace(r.Comment))
                        {
                            <button type="button"
                                    class="btn btn-sm btn-outline-info"
                                    data-bs-toggle="modal"
                                    data-bs-target="#commentModal"
                                    data-comment="@r.Comment"
                                    data-animal="@r.Animal?.Name"
                                    data-user="@r.FullName">
                                Виж
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                Няма
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="commentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Коментар към заявката</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-2">
                        <strong>Животно:</strong> <span id="commentAnimal"></span>
                    </div>

                    <div class="mb-2">
                        <strong>Кандидат:</strong> <span id="commentUser"></span>
                    </div>

                    <hr />

                    <div id="commentText" style="white-space: pre-wrap;"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Затвори</button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
    <script>
        const commentModal = document.getElementById('commentModal');

        if (commentModal) {
            commentModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;

                const comment = button.getAttribute('data-comment');
                const animal = button.getAttribute('data-animal');
                const user = button.getAttribute('data-user');

                document.getElementById('commentText').textContent = comment ?? '';
                document.getElementById('commentAnimal').textContent = animal ?? '';
                document.getElementById('commentUser').textContent = user ?? '';
            });
        }
    </script>
    }
}
