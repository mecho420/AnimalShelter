@page
@model AnimalShelter.Pages.Admin.Animals.IndexModel
@using AnimalShelter.Models.Enums
@using AnimalShelter.Helpers

@{
    ViewData["Title"] = "Животни (Admin)";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">
        @TempData["Error"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Животни</h1>
    <a class="btn btn-primary" asp-page="/Admin/Animals/Create">+ Добави животно</a>
</div>

<form method="get" class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">

            <div class="col-md-4">
                <label class="form-label">Търсене по име</label>
                <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Вид</label>
                <input type="text" name="Species" value="@Model.Species" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Статус</label>
                <select name="Status" class="form-select">
                    <option value="">Всички</option>
                    <option value="ForAdoption" selected="@(Model.Status == AnimalStatus.ForAdoption)">За осиновяване</option>
                    <option value="Adopted" selected="@(Model.Status == AnimalStatus.Adopted)">Осиновено</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100">Филтрирай</button>
            </div>

        </div>
    </div>
</form>

@if (Model.Result == null || !Model.Result.Items.Any())
{
    <div class="alert alert-info">Няма добавени животни.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:120px;">Снимка</th>
                <th>Име</th>
                <th>Вид</th>
                <th>Възраст</th>
                <th>Пол</th>
                <th>Статус</th>
                <th style="width:160px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Result.Items)
            {
                var img = string.IsNullOrWhiteSpace(a.ImagePath) ? "/images/animals/default-dog.jpg" : a.ImagePath;
                <tr>
                    <td>
                        <img src="@img" style="height:70px;width:110px;object-fit:cover;" class="rounded" />
                    </td>
                    <td>
                        <strong>@a.Name</strong><br />
                        <a asp-page="/Animals/Details" asp-route-id="@a.Id">Публични детайли</a>
                    </td>
                    <td>@a.Species</td>
                    <td>@a.Age</td>
                    <td>@a.Gender.GetDisplayName()</td>
                    <td>@a.Status.GetDisplayName()</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary"
                           asp-page="/Admin/Animals/Edit"
                           asp-route-id="@a.Id">Редакция</a>

                        <button type="button"
                                class="btn btn-sm btn-outline-danger ms-1"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-animal-id="@a.Id"
                                data-animal-name="@a.Name">
                            Изтрий
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Потвърждение</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
                </div>

                <div class="modal-body">
                    Сигурен ли си, че искаш да изтриеш животното:
                    <strong id="deleteAnimalName"></strong>?
                    <div class="text-danger mt-2">Това действие не може да бъде върнато.</div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отказ</button>

                    <form method="post" asp-page-handler="Delete">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteAnimalId" />
                        <button type="submit" class="btn btn-danger">Да, изтрий</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-animal-id');
            const name = button.getAttribute('data-animal-name');

            document.getElementById('deleteAnimalId').value = id;
            document.getElementById('deleteAnimalName').textContent = name;
        });
    </script>
    }
}

@if (Model.Result.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <li class="page-item @(Model.Result.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   asp-page="./Index"
                   asp-route-PageNumber="@(Model.PageNumber - 1)"
                   asp-route-SearchTerm="@Model.SearchTerm"
                   asp-route-Species="@Model.Species"
                   asp-route-Status="@Model.Status">
                    Предишна
                </a>
            </li>

            @for (int i = 1; i <= Model.Result.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Result.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-route-PageNumber="@i"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-Species="@Model.Species"
                       asp-route-Status="@Model.Status">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.Result.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   asp-page="./Index"
                   asp-route-PageNumber="@(Model.PageNumber + 1)"
                   asp-route-SearchTerm="@Model.SearchTerm"
                   asp-route-Species="@Model.Species"
                   asp-route-Status="@Model.Status">
                    Следваща
                </a>
            </li>

        </ul>
    </nav>
}
